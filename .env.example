# GitHub OAuth App credentials (Settings → Developer settings → OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 32+ random bytes used to encrypt the session cookie.
# Generate locally with:  openssl rand -base64 48
COOKIE_SECRET=

# owner/repo where config/service-fees.json lives and PRs are opened
GITHUB_REPO=zagamealexandre/service-fees-admin

# (optional) Comma-separated list of allowed base branches. The first one is the default
# environment. When more than one is configured, the editor shows a branch picker in the header.
# Example: GITHUB_BRANCHES=main,staging
# GITHUB_BRANCHES=main

# (optional, legacy single-branch alias — superseded by GITHUB_BRANCHES)
# GITHUB_BASE_BRANCH=main
