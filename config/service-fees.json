        "override": {
          "fixed": {
            "productFee": {
              "2|4|8": {
                "MX": { "Default": { "Amount": 2, "Currency": "USD" } },
                "NG": { "Default": { "Amount": 2, "Currency": "USD" } }
              }
            }
          }
        }
      }
    ]
