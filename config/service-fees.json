        "bands": [
          { "minPriceInclusive": 0.0, "maxPriceExclusive": 5.0, "feePercent": 20.0 },
          { "minPriceInclusive": 5.0, "maxPriceExclusive": 8.0, "feePercent": 18.0 },
          { "minPriceInclusive": 8.0, "maxPriceExclusive": 12.0, "feePercent": 16.0 },
