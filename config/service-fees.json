            "bands": [
              { "minPriceInclusive": 0.0, "maxPriceExclusive": 5.0, "feePercent": 22.0 },
              { "minPriceInclusive": 5.0, "maxPriceExclusive": 8.0, "feePercent": 19.0 },
              { "minPriceInclusive": 8.0, "maxPriceExclusive": 12.0, "feePercent": 17.0 },
              { "minPriceInclusive": 12.0, "maxPriceExclusive": 20.0, "feePercent": 13.0 },
              { "minPriceInclusive": 20.0, "maxPriceExclusive": null, "feePercent": 12.0 }
            ]
          }
        }
      },
      {
        "scope": { "category": "Credit" },
        "override": {
          "relative": {
            "minFee": 0.75,
            "bands": [
              { "minPriceInclusive": 12.0, "maxPriceExclusive": 20.0, "feePercent": 13.0 },
              { "minPriceInclusive": 20.0, "maxPriceExclusive": null, "feePercent": 12.0 }
            ]
          }
        }
      },
      {
        "scope": { "country": "IT" },
        "override": {
